@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản trị KFC Web App</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            background: #f8f9fa;
        }
        .admin-sidebar {
            min-height: 100vh;
            background: #212529;
            color: #fff;
        }
        .admin-sidebar .nav-link {
            color: #fff;
            font-weight: 500;
        }
        .admin-sidebar .nav-link.active, .admin-sidebar .nav-link:hover {
            background: #e4002b;
            color: #fff;
        }
        .admin-header {
            background: #fff;
            border-bottom: 1px solid #dee2e6;
            padding: 1rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .admin-content {
            padding: 2rem;
        }
        /* media query cho responsive */
        @@media (max-width: 767.98px) {
            .admin-sidebar { min-height: auto; }
            .admin-content { padding: 1rem; }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-2 d-none d-md-block admin-sidebar sidebar py-4">
                <div class="sidebar-sticky">
                    <h4 class="text-center mb-4"><i class="fas fa-user-shield me-2"></i>Admin</h4>
                    <ul class="nav flex-column gap-2">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminOrder" ? "active" : "")" asp-controller="AdminOrder" asp-action="Index"><i class="fas fa-clipboard-list me-2"></i>Quản lý đơn hàng</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminProduct" ? "active" : "")" asp-controller="AdminProduct" asp-action="Index"><i class="fas fa-box me-2"></i>Quản lý sản phẩm</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminCategory" ? "active" : "")" asp-controller="AdminCategory" asp-action="Index"><i class="fas fa-tags me-2"></i>Quản lý danh mục</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminUser" ? "active" : "")" asp-controller="AdminUser" asp-action="Index"><i class="fas fa-users-cog me-2"></i>Quản lý người dùng</a>
                        </li>
                        <li class="nav-item mt-4">
                            <a class="nav-link" asp-controller="Home" asp-action="Index"><i class="fas fa-home me-2"></i>Về trang chủ</a>
                        </li>
                    </ul>
                </div>
            </nav>
            <main class="col-md-10 ms-sm-auto px-md-4">
                <div class="admin-header">
                    <div>
                        <h5 class="mb-0">@ViewData["Title"]</h5>
                    </div>
                    <div>
                        <span class="me-3"><i class="fas fa-user-circle"></i> @User.Identity?.Name</span>
                        <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger btn-sm"><i class="fas fa-sign-out-alt me-1"></i>Đăng xuất</a>
                    </div>
                </div>
                <div class="admin-content">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html> 